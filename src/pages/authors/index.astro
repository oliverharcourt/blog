---
import AuthorCard from '@/components/author-card.astro'
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import { SHOW_AUTHORS } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getAllAuthors } from '@/lib/data-utils'

const authors = SHOW_AUTHORS ? await getAllAuthors() : []
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Authors" noindex={!SHOW_AUTHORS} />
  {
    SHOW_AUTHORS ? (
      <>
        <Breadcrumbs items={[{ label: 'Authors', icon: 'lucide:users' }]} />
        {authors.length > 0 ? (
          <ul class="flex flex-col gap-4">
            {authors.map((author) => (
              <li>
                <AuthorCard author={author} />
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-muted-foreground text-center">No authors found.</p>
        )}
      </>
    ) : (
      <p class="text-muted-foreground text-center">Not available.</p>
    )
  }
</Layout>
