---
import BlogCard from '@/components/blog-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getRecentPosts } from '@/lib/data-utils'

const blog = await getRecentPosts(SITE.featuredPostCount)
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Home" />
  <section class="relative py-8 sm:py-16">
    <span
      class="text-accent/15 pointer-events-none absolute right-0 bottom-2 z-0 text-[5rem] leading-none whitespace-nowrap select-none sm:text-[7rem]"
      style="font-family: 'Zen Antique', serif;"
      aria-hidden="true">一日一歩</span
    >
    <p
      class="text-muted-foreground relative z-10 mb-3 font-mono text-xs tracking-[0.3em] uppercase"
    >
      [ PERSONAL LOG // 2026 ]
    </p>
    <h1
      class="text-foreground relative z-10 font-mono text-4xl font-bold tracking-tight break-words lowercase sm:text-6xl"
    >
      test title<span
        class="terminal-cursor"
        style="display: inline-block; color: var(--accent); margin-left: 0.1em; animation: terminal-blink 1s steps(1, end) infinite;"
        aria-hidden="true">█</span
      >
    </h1>
  </section>

  <script>
    function restartTerminalCursors() {
      document.querySelectorAll('.terminal-cursor').forEach((el) => {
        if (!(el instanceof HTMLElement)) return
        el.style.animation = 'none'
        void el.offsetWidth
        el.style.animation = 'terminal-blink 1s steps(1, end) infinite'
      })
    }
    restartTerminalCursors()
    document.addEventListener('astro:page-load', restartTerminalCursors)
  </script>
  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Latest posts</h2>
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link
        href="/blog"
        class={buttonVariants({ variant: 'ghost' }) + ' group'}
      >
        See all posts <span
          class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
</Layout>
